{
  "name": "@ipcow/tools-core",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-first IP, DNS & email tool logic: an RFC 8484 DoH client (Quad9), DNS record/reverse/SPF/DMARC/DKIM/CAA/MX lookups, CIDR + IP math, and RDAP. Pure, typed, transport-agnostic.",
  "license": "MIT",
  "author": "Michal Ferber",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MichalAFerber/ipcow-tools.git"
  },
  "homepage": "https://ipcow.com",
  "keywords": [
    "ip",
    "dns",
    "doh",
    "dns-over-https",
    "rfc8484",
    "quad9",
    "cidr",
    "subnet",
    "ipv4",
    "ipv6",
    "spf",
    "dmarc",
    "dkim",
    "caa",
    "mx",
    "rdap",
    "whois",
    "privacy"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
