# ipcow probe — Caddy reverse proxy with automatic HTTPS.
#
# One config per box; this is the IPv4 box. For the IPv6 box, swap the hostnames as noted in
# the trailing comments (ipv6.ipcow.com / checkipv6.ipcow.com).
#
# CF_API_TOKEN (Zone:DNS:Edit on ipcow.com) lives in /etc/caddy/ipcow.env (root, chmod 600) and
# is used for the DNS-01 challenge: checkip.ipcow.com is dual-stack across the two single-stack
# boxes, so HTTP-01 can't validate it (Let's Encrypt would reach the other box). Caddy must be
# built with the caddy-dns/cloudflare module (xcaddy build --with github.com/caddy-dns/cloudflare).
# See README.

# Per-stack JSON echo {ip,stack} — the site hero calls this. HTTP-01, single host.
ipv4.ipcow.com {                                          # IPv6 box: ipv6.ipcow.com
	encode zstd gzip
	reverse_proxy 127.0.0.1:8000
}

# Classic plain-text checkip endpoints — plain HTTP (no redirect) so `curl checkip.ipcow.com`
# (no scheme = port 80) returns the IP directly instead of a 308 to HTTPS.
http://checkip.ipcow.com, http://checkipv4.ipcow.com {   # IPv6 box: http://checkip... http://checkipv6...
	reverse_proxy 127.0.0.1:8000
}

# ...and the same hosts over HTTPS (DNS-01 via Cloudflare).
checkip.ipcow.com, checkipv4.ipcow.com {                 # IPv6 box: checkip.ipcow.com, checkipv6.ipcow.com
	encode zstd gzip
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
	reverse_proxy 127.0.0.1:8000
}
