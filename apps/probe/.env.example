# Copy to /etc/ipcow-probe.env on each box and fill in.

# Which stack this box serves: "ipv4" or "ipv6".
PROBE_STACK=ipv4

# Shared secret the Astro /api/probe route sends as the X-Probe-Key header.
# Generate once (openssl rand -hex 32) and store the same value as a secret on the web app.
PROBE_KEY=replace-me

# Address the Go server listens on (Caddy reverse-proxies to it).
PROBE_ADDR=127.0.0.1:8000

# Note: the public endpoints (/, /healthz, /speedtest/*) send Access-Control-Allow-Origin: *
# so the site works from any origin; no allow-list to configure.
